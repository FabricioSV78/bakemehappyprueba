      <path d={`M${left} ${topY}v${height}c0 ${ry} ${width} ${ry} ${width} 0V${topY}`} fill={cream} />
      <path d={`M${left} ${bottomY}c0 ${ry} ${width} ${ry} ${width} 0`} />
    </g>
  );
}

