        className={`mb-3 text-xs font-semibold uppercase tracking-[0.18em] ${
          light ? "text-blush" : "text-plum"
        }`}
      >
        {eyebrow}
      </span>
      <h2
        className={`w-full min-w-0 break-words font-display text-3xl leading-tight sm:text-5xl ${titleMeasure} ${
