    setActiveCategory("Todos");
    setPriceRange(priceBounds);
    setPortionRange(portionRanges[0].label);
    setFlavor(flavorOptions[0]);
    setOccasion(occasionOptions[0]);
    setSortBy(sortOptions[0]);
    setSearchTerm("");
